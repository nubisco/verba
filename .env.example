# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=verba
POSTGRES_PASSWORD=change-me
POSTGRES_DB=verba

# ─── API ──────────────────────────────────────────────────────────────────────
# Must be a long random string. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# Origin of the web frontend (no trailing slash)
CORS_ORIGIN=https://verba.example.com

# ─── Web ──────────────────────────────────────────────────────────────────────
# Port the web frontend listens on (mapped to container 8080)
WEB_PORT=80

# ─── Email (optional, OTP codes logged to stdout if unset) ───────────────────
# Resend (preferred)
# RESEND_API_KEY=re_xxxx

# SMTP (fallback)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_FROM=noreply@example.com
# SMTP_USER=
# SMTP_PASS=

# ─── Auth mode ───────────────────────────────────────────────────────────────
# Set to true to enable password login (default: OTP only)
# ENABLE_LOCAL_PASSWORD=false
