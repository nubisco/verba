# ─── API ──────────────────────────────────────────────────────────────────────
# Backend API base URL
VITE_API_URL=http://localhost:4000

# ─── Error tracking ───────────────────────────────────────────────────────────
# Sentry DSN: leave empty to disable error reporting
VITE_SENTRY_DSN=

# ─── Analytics ────────────────────────────────────────────────────────────────
# PostHog project API key: leave empty to disable
# Analytics are automatically disabled in development (import.meta.env.PROD check)
VITE_POSTHOG_KEY=

# PostHog ingestion host. Defaults to EU cloud (https://eu.i.posthog.com) if unset.
# Use https://us.i.posthog.com for US cloud, or your own reverse proxy.
VITE_POSTHOG_HOST=https://eu.i.posthog.com
